<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Log ind – Fairkredit Samarbejdspartner Portal</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="page-login">
  <div class="login-wrapper">
    <div class="login-header">
      <img src="/images/logo-fairkredit_redorange.png" alt="Fairkredit Logo" class="login-logo">
      <h2 class="mb-6" style="color: #F15A45">Fair.Flow</h2>
      <h3>Samarbejdspartner portal</h3>
      <p class="text-muted">Log ind for at oprette og sende leads</p>
    </div>

    <div class="card login-card">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/login" method="POST" novalidate>
        <div class="form-group">
          <label for="email">Email <span class="required">*</span></label>
          <input
            id="email"
            name="email"
            type="email"
            class="input"
            placeholder="din@email.dk"
            required
            autocomplete="email"
          >
        </div>

        <div class="form-group">
          <label for="password">Adgangskode <span class="required">*</span></label>
          <input
            id="password"
            name="password"
            type="password"
            class="input"
            placeholder="••••••••"
            required
            autocomplete="current-password"
          >
        </div>

        <button type="submit" class="btn btn-primary btn-full" id="loginBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Log ind
        </button>
      </form>

      <div class="login-footer">
        <p class="text-muted text-sm">
          Glemt adgangskode?
          <a href="#" class="link">Kontakt support</a>
        </p>
      </div>
    </div>

    <p class="text-center text-muted text-sm mt-4">© 2026 Fairkredit. Alle rettigheder forbeholdes.</p>
  </div>

  <script src="/js/login.js"></script>
</body>
</html>
