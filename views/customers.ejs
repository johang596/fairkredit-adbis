  <title>Kunder – Fairkredit Portal</title>
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .data-table tbody tr {
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .data-table tbody tr:hover {
      background-color: rgba(37, 99, 235, 0.05);
    }
    .data-table tbody tr:hover td.customer-name {
      color: #1e40af;
      text-decoration: underline;
    }
    td.customer-name {
      color: #2563eb;
      font-weight: 500;
      transition: color 0.2s;
    }
  </style>
</head>
